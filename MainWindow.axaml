<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MessengerGui.Models"
        xmlns:local="clr-namespace:MessengerGui"
        x:Class="MessengerGui.MainWindow"
        Title="Messenger GUI" Width="900" Height="500">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#ff007f"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid ColumnDefinitions="200, 250, *">
            <Border Grid.Column="0" Background="#2d2d2d">
                <StackPanel>
                    <TextBlock Text="Користувачі" Foreground="White" Margin="10"/>
                    <ListBox Name="UserListBox" Background="Transparent" SelectionChanged="User_Selected">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:User">
                                <TextBlock Text="{Binding Username}" Foreground="White" Padding="10">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Видалити користувача" Click="Delete_User_Click"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="+ Додати користувача" Click="Open_AddUser_Dialog" Margin="10" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Background="#1e1e1e">
                <TextBlock Text="Ваші чати" Foreground="White" Margin="10"/>
                <ListBox Name="ChatList" Background="Transparent" SelectionChanged="Chat_Selected" KeyDown="ChatList_KeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Conversation">
                            <TextBlock Text="{Binding Title}" Foreground="White" Padding="10">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Видалити чат" Click="Delete_Chat_Click"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="+ Новий чат" Click="Create_Chat_Click" Margin="10" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Grid Grid.Column="2" RowDefinitions="Auto, Auto, *, Auto" Margin="15">
                <TextBox Name="SearchInput" Grid.Row="0" Watermark="🔍 Пошук..." Margin="0,0,0,5" TextChanged="Search_TextChanged"/>
                
                <ListBox Name="SearchResults" Grid.Row="1" MaxHeight="150" SelectionChanged="Result_Selected" IsVisible="False" Background="#e0e0e0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:MessageViewModel">
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding SenderName}" FontWeight="Bold" Foreground="#333"/>
                                <TextBlock Text="{Binding Text}" FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ListBox Name="MessageList" Grid.Row="2" Background="#f0f0f0" KeyDown="MessageList_KeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:MessageViewModel">
                            <StackPanel>
                                <TextBlock Text="{Binding DateHeader}" IsVisible="{Binding ShowDateHeader}" HorizontalAlignment="Center" Foreground="Gray" FontSize="10"/>
                                <StackPanel HorizontalAlignment="{Binding IsCurrentUser, Converter={x:Static local:BoolToAlignmentConverter.Instance}}">
                                    <Border Margin="5" Padding="10" CornerRadius="10" Background="{Binding Converter={x:Static local:MessageColorConverter.Instance}}">
                                        <TextBlock Text="{Binding Text}" Foreground="Black"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="5" Margin="0,10,0,0">
                    <Button Name="EmojiButton" Content="😊" Click="Open_Emoji_Popup" Width="40"/>
                    <TextBox Name="MessageInput" Width="260" Watermark="Текст..." KeyDown="MessageInput_KeyDown"/>
                    <Button Content="Надіслати" Click="Send_Message"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Popup Name="EmojiPopup" PlacementTarget="{Binding #EmojiButton}" IsOpen="False">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="5" CornerRadius="5">
                <UniformGrid Columns="4" Width="160">
                    <Button Content="😀" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="😂" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="😍" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="😎" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="🤔" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="🥺" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="👍" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="🔥" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="❤️" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="✨" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="🎉" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                    <Button Content="🚀" Click="Insert_Emoji" Background="Transparent" Foreground="Black" HorizontalContentAlignment="Center"/>
                </UniformGrid>
            </Border>
        </Popup>
    </Grid>
</Window>